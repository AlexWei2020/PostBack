# ─── Database (Postgres — Supabase or Neon) ────────────────────────────
# On Vercel serverless, use the POOLED connection string:
#   Supabase → Settings → Database → Connection string → "Transaction" mode
#             postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   Neon     → the …-pooler.<region>.neon.tech string
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── App base URL ──────────────────────────────────────────────────────
# Local dev: http://localhost:3000 ; Production: https://your-vercel-domain.com
PUBLIC_BASE_URL=http://localhost:3000

# ─── Vercel Blob (postcard image storage) ──────────────────────────────
# Create a Blob store in the Vercel dashboard → Storage, then copy the token.
# `vercel env pull` sets this automatically when linked.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ─── Casdoor OAuth (auth.geekpie.club) ─────────────────────────────────
# NEXT_PUBLIC_* values are inlined at build time — changing them needs a rebuild.
NEXT_PUBLIC_CASDOOR_SERVER_URL=https://auth.geekpie.club
NEXT_PUBLIC_CASDOOR_CLIENT_ID=your-client-id
NEXT_PUBLIC_CASDOOR_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_CASDOOR_SIGNIN_URL=https://auth.geekpie.club/login/oauth/authorize
NEXT_PUBLIC_CASDOOR_SCOPE=openid profile email

# Notes for Vercel deployment:
#   - Set PUBLIC_BASE_URL and NEXT_PUBLIC_CASDOOR_REDIRECT_URI to your production domain
#   - Register the production redirect URI in the Casdoor application config
#   - Add every variable above to Vercel → Project → Settings → Environment Variables
